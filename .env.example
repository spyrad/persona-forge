# Supabase-Projekt: Settings → API
# SUPABASE_KEY = Publishable Key (sb_publishable_..., Legacy-Name "anon key") —
# RLS-unterworfen. NIEMALS den service_role/Secret-Key verwenden (hebelt RLS aus).
# Identisch in .dev.vars pflegen (maßgeblich für den workerd-Dev-Server).
SUPABASE_URL=###
SUPABASE_KEY=###

# ENCRYPTION_KEY = base64-kodierter 32-Byte-Schlüssel (AES-256-GCM) für API-Keys at rest.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Identisch in .dev.vars pflegen; in Prod als GitHub-Secret (Deploy-Job synct es als Worker-Secret).
ENCRYPTION_KEY=###
