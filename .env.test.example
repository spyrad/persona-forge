# Integration-Test-Env — Vorlage. Kopiere zu `.env.test` (gitignored) und fülle
# die Werte aus `npx supabase status` (lokale Instanz, NICHT Remote/Prod).
#
# Der Safety-Guard in src/test/integration/setup.ts verweigert den Lauf, wenn
# SUPABASE_URL nicht auf 127.0.0.1/localhost zeigt.

# Lokale Supabase-API (Default-Port aus supabase/config.toml)
SUPABASE_URL=http://127.0.0.1:54321

# Lokaler anon-/publishable-Key aus `npx supabase status` (NIE service_role)
SUPABASE_KEY=

# base64-kodierter 32-Byte-Schlüssel (AES-256-GCM); createModelConfig braucht ihn.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
