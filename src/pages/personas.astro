---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { listPersonas } from "@/lib/services/personas";
import type { PersonaView } from "@/types";
import PersonaCatalog from "@/components/personas/PersonaCatalog";

// /personas ist via PROTECTED_ROUTES geschuetzt — hier ist der User authentifiziert.
const { user } = Astro.locals;

// Initiale Liste server-seitig laden (RLS-gescoped: eigene + globale). Faellt
// Supabase/Service aus, signalisiert `loadError` der Island einen sichtbaren
// Hinweis statt einer stumm leeren Liste; die Island laedt nach Mutationen neu.
let initialPersonas: PersonaView[] = [];
let loadError = false;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase && user) {
  try {
    initialPersonas = await listPersonas(supabase, user.id);
  } catch {
    loadError = true;
  }
} else {
  loadError = true;
}
---

<AppLayout
  title="Personas"
  eyebrow="03 — personas"
  heading="Personas"
  lead={`Reusable cognitive profiles for ${user?.email ?? ""}. Personas are immutable — duplicating creates your own editable variant.`}
>
  <PersonaCatalog client:load initialPersonas={initialPersonas} loadError={loadError} />
</AppLayout>
