---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listPersonas } from "@/lib/services/personas";
import type { PersonaView } from "@/types";
import PersonaCatalog from "@/components/personas/PersonaCatalog";

// /personas ist via PROTECTED_ROUTES geschuetzt — hier ist der User authentifiziert.
const { user } = Astro.locals;

// Initiale Liste server-seitig laden (RLS-gescoped: eigene + globale). Faellt
// Supabase/Service aus, signalisiert `loadError` der Island einen sichtbaren
// Hinweis statt einer stumm leeren Liste; die Island laedt nach Mutationen neu.
let initialPersonas: PersonaView[] = [];
let loadError = false;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase && user) {
  try {
    initialPersonas = await listPersonas(supabase, user.id);
  } catch {
    loadError = true;
  }
} else {
  loadError = true;
}
---

<Layout title="Personas">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-3xl">
      <header class="mb-8 flex items-start justify-between gap-4">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            Personas
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">
            Wiederverwendbare kognitive Profile für <span class="text-white">{user?.email}</span>. Personas sind
            unveränderlich — „Kopieren" erzeugt eine eigene, bearbeitbare Variante.
          </p>
        </div>
        <a
          href="/dashboard"
          class="shrink-0 rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-sm transition-colors hover:bg-white/20"
        >
          ← Dashboard
        </a>
      </header>

      <PersonaCatalog client:load initialPersonas={initialPersonas} loadError={loadError} />
    </div>
  </div>
</Layout>
