---
import Layout from "@/layouts/Layout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: "Registration successful",
      description: "Your account has been created. You can now sign in.",
      linkText: "Go to sign in",
    }
  : {
      emoji: "📧",
      heading: "Check your email",
      description: "We've sent a confirmation link to your email address. Click it to activate your account.",
      linkText: "Back to sign in",
    };
---

<Layout title={content.heading}>
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground w-full max-w-sm rounded-2xl border p-8 text-center">
      <div class="mb-4 text-5xl">{content.emoji}</div>
      <h1 class="text-foreground mb-3 text-2xl font-bold">
        {content.heading}
      </h1>
      <p class="text-muted-foreground mb-6">{content.description}</p>
      <a href="/auth/signin" class="text-primary text-sm hover:underline">
        {content.linkText}
      </a>
    </div>
  </div>
</Layout>
