---
import Layout from "@/layouts/Layout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign up">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card text-foreground w-full max-w-sm rounded-2xl border p-8">
      <h1 class="text-foreground mb-6 text-center text-2xl font-bold">Sign up</h1>
      <SignUpForm serverError={error} client:load />
      <p class="text-muted-foreground mt-4 text-center text-sm">
        Already have an account? <a href="/auth/signin" class="text-primary hover:underline">Sign in</a>
      </p>
    </div>
  </div>
</Layout>
