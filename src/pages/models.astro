---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { listModelConfigs } from "@/lib/services/model-configs";
import { listModelProfiles } from "@/lib/services/model-profiles";
import type { ModelConfigView, ModelProfileListItem } from "@/types";
import ModelConfigManager from "@/components/models/ModelConfigManager";
import ModelProfilePicker from "@/components/models/ModelProfilePicker";

// /models ist via PROTECTED_ROUTES geschuetzt — hier ist der User authentifiziert.
const { user } = Astro.locals;

// Initiale Liste server-seitig laden (RLS-gescoped ueber die Request-Session).
// Faellt Supabase/Service aus, signalisiert `loadError` der Island einen
// sichtbaren Hinweis statt einer stumm leeren Liste; die Island laedt nach
// Mutationen ohnehin neu.
let initialConfigs: ModelConfigView[] = [];
let loadError = false;
// Modell-Profile (Baseline-Aggregation) fuer den Einstieg in /models/profile.
// Bewusst statisch (aendert sich nur durch abgeschlossene Laeufe, nicht durch
// Config-Mutationen der Island); Service-Ausfall degradiert still zur leeren
// Liste — die Config-Verwaltung bleibt nutzbar.
let profileItems: ModelProfileListItem[] = [];
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  try {
    initialConfigs = await listModelConfigs(supabase);
  } catch {
    loadError = true;
  }
  try {
    profileItems = await listModelProfiles(supabase);
  } catch {
    profileItems = [];
  }
} else {
  loadError = true;
}
---

<AppLayout
  title="Model configs"
  eyebrow="02 — model configs"
  heading="Model configs"
  lead={`OpenAI-compatible models for ${user?.email ?? ""}. API keys are stored encrypted and never shown again.`}
>
  <ModelConfigManager client:load initialConfigs={initialConfigs} loadError={loadError} />

  <section class="mt-10 space-y-4">
    <div>
      <h2 class="text-muted-foreground font-mono text-xs tracking-[0.2em] uppercase">model profiles — baseline</h2>
      <p class="text-muted-foreground mt-1 text-sm">
        Aggregated results per distinct model name, pooled across all completed baseline runs (no persona).
      </p>
    </div>
    {
      profileItems.length === 0 ? (
        <p class="border-border bg-card text-muted-foreground rounded-2xl border px-4 py-5 text-sm">
          No baseline runs yet. Start a run with “No persona (baseline)” to build a model profile.
        </p>
      ) : (
        // Insel (Phase 4.1): Karten + Vergleichs-Auswahl (2–4 Modelle) mit
        // Sticky-Leiste; Profil-Links bleiben erhalten.
        <ModelProfilePicker client:load items={profileItems} />
      )
    }
  </section>
</AppLayout>
