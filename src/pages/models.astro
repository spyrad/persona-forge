---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listModelConfigs } from "@/lib/services/model-configs";
import type { ModelConfigView } from "@/types";
import ModelConfigManager from "@/components/models/ModelConfigManager";

// /models ist via PROTECTED_ROUTES geschuetzt — hier ist der User authentifiziert.
const { user } = Astro.locals;

// Initiale Liste server-seitig laden (RLS-gescoped ueber die Request-Session).
// Faellt ENCRYPTION_KEY/Supabase aus, bleibt die Liste leer; die Island laedt
// nach Mutationen ohnehin neu.
let initialConfigs: ModelConfigView[] = [];
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  try {
    initialConfigs = await listModelConfigs(supabase);
  } catch {
    initialConfigs = [];
  }
}
---

<Layout title="Model Configs">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-3xl">
      <header class="mb-8 flex items-start justify-between gap-4">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            Model Configs
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">
            OpenAI-kompatible Modelle für <span class="text-white">{user?.email}</span>. API-Keys werden verschlüsselt
            gespeichert und nie wieder angezeigt.
          </p>
        </div>
        <a
          href="/dashboard"
          class="shrink-0 rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-sm transition-colors hover:bg-white/20"
        >
          ← Dashboard
        </a>
      </header>

      <ModelConfigManager client:load initialConfigs={initialConfigs} />
    </div>
  </div>
</Layout>
