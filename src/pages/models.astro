---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listModelConfigs } from "@/lib/services/model-configs";
import type { ModelConfigView } from "@/types";
import ModelConfigManager from "@/components/models/ModelConfigManager";

// /models ist via PROTECTED_ROUTES geschuetzt — hier ist der User authentifiziert.
const { user } = Astro.locals;

// Initiale Liste server-seitig laden (RLS-gescoped ueber die Request-Session).
// Faellt Supabase/Service aus, signalisiert `loadError` der Island einen
// sichtbaren Hinweis statt einer stumm leeren Liste; die Island laedt nach
// Mutationen ohnehin neu.
let initialConfigs: ModelConfigView[] = [];
let loadError = false;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase) {
  try {
    initialConfigs = await listModelConfigs(supabase);
  } catch {
    loadError = true;
  }
} else {
  loadError = true;
}
---

<Layout title="Model Configs">
  <div class="min-h-screen px-4 py-10">
    <div class="mx-auto max-w-3xl">
      <header class="mb-8">
        <h1 class="text-foreground text-3xl font-bold">Model Configs</h1>
        <p class="text-muted-foreground mt-1 text-sm">
          OpenAI-kompatible Modelle für <span class="text-foreground">{user?.email}</span>. API-Keys werden
          verschlüsselt gespeichert und nie wieder angezeigt.
        </p>
      </header>

      <ModelConfigManager client:load initialConfigs={initialConfigs} loadError={loadError} />
    </div>
  </div>
</Layout>
