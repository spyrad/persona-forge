---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { getRunResult } from "@/lib/services/runs";
import { listPersonas } from "@/lib/services/personas";
import { listModelConfigs } from "@/lib/services/model-configs";
import RunComparison from "@/components/runs/RunComparison";
import type { ModelConfigView, PersonaView, RunComparisonSide, RunComparisonView, RunResultView } from "@/types";

// /runs/compare ist via PROTECTED_ROUTES (startsWith "/runs") geschuetzt. Diese
// statische Route schattet bewusst die dynamische /runs/[id] ab (sonst landet
// "compare" als id dort). Beide Laeufe werden RLS-gescoped geladen; alle
// Edge-Cases enden in einem erklaerenden Zustand statt einem 500.
const { user } = Astro.locals;
const a = Astro.url.searchParams.get("a") ?? "";
const b = Astro.url.searchParams.get("b") ?? "";

/** Loest die Anzeige-Labels eines Laufs aus den sichtbaren Persona-/Modell-Listen. */
function resolveSide(result: RunResultView, personas: PersonaView[], models: ModelConfigView[]): RunComparisonSide {
  const { run } = result;
  const persona = run.personaId ? personas.find((p) => p.id === run.personaId) : null;
  const model = run.modelConfigId ? models.find((m) => m.id === run.modelConfigId) : null;
  return {
    result,
    // Baseline (bewusst ohne Persona) VOR den Fallbacks: FK auf null → der Bezug
    // wurde geloescht; ID gesetzt aber nicht sichtbar (z. B. fremde private
    // Persona hinter globalem Lauf) → unbekannt.
    personaName: run.isBaseline
      ? "baseline (no persona)"
      : (persona?.name ?? (run.personaId ? "(unknown)" : "(deleted)")),
    modelLabel: model?.label ?? (run.modelConfigId ? "(unknown)" : "(deleted)"),
    modelName: model?.modelName ?? null,
  };
}

/** Explanation for a run that is not comparable (not `ready`). */
function notReadyReason(result: RunResultView): string {
  return result.state === "unfinished" ? "is not finished yet" : "produced no usable repetitions";
}

type PageState = "missing" | "same" | "notFound" | "notReady" | "loadError" | "ready";

let pageState: PageState = "ready";
let view: RunComparisonView | null = null;
let notReadyDetail = "";

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase || !user) {
  pageState = "loadError";
} else if (!a || !b) {
  pageState = "missing";
} else if (a === b) {
  pageState = "same";
} else {
  try {
    const [ra, rb] = await Promise.all([getRunResult(supabase, user.id, a), getRunResult(supabase, user.id, b)]);
    if (!ra || !rb) {
      pageState = "notFound";
    } else if (ra.state !== "ready" || rb.state !== "ready") {
      pageState = "notReady";
      const parts: string[] = [];
      if (ra.state !== "ready") parts.push(`Run A ${notReadyReason(ra)}`);
      if (rb.state !== "ready") parts.push(`Run B ${notReadyReason(rb)}`);
      notReadyDetail = parts.join("; ");
    } else {
      const [personas, models] = await Promise.all([listPersonas(supabase, user.id), listModelConfigs(supabase)]);
      view = { a: resolveSide(ra, personas, models), b: resolveSide(rb, personas, models) };
    }
  } catch {
    pageState = "loadError";
  }
}

// Nicht sichtbar/vorhanden → 404 (Status ohne Top-Level-`return`; ein `return`
// im Astro-Frontmatter crasht die getypte no-misused-promises-Regel).
if (pageState === "notFound") {
  Astro.response.status = 404;
}
---

<AppLayout
  title="Compare runs"
  eyebrow="04 — comparison"
  heading="Compare runs"
  lead="Two completed OEJTS runs side by side — distribution per axis with their spreads."
>
  {
    pageState === "loadError" ? (
      <p class="border-destructive/30 bg-destructive/10 text-destructive rounded-2xl border px-4 py-5 text-sm">
        Could not load the comparison. Please reload.
      </p>
    ) : pageState === "missing" ? (
      <p class="border-border bg-card text-muted-foreground rounded-2xl border px-4 py-5 text-sm">
        Select two runs to compare — use the “Compare” checkboxes in the runs list.
      </p>
    ) : pageState === "same" ? (
      <p class="border-border bg-card text-muted-foreground rounded-2xl border px-4 py-5 text-sm">
        Select two <em>different</em> runs — a run cannot be compared with itself.
      </p>
    ) : pageState === "notFound" ? (
      <p class="border-border bg-card text-muted-foreground rounded-2xl border px-4 py-5 text-sm">
        At least one of the runs was not found (deleted or not visible).
      </p>
    ) : pageState === "notReady" ? (
      <p class="border-chart-2/40 bg-chart-2/10 text-chart-2 rounded-2xl border px-4 py-5 text-sm">
        Not comparable: {notReadyDetail}. Only completed runs with usable repetitions can be compared.
      </p>
    ) : view ? (
      // Rein präsentational (keine Interaktivität) → statisch gerendert, kein
      // Client-JS, keine Hydration.
      <RunComparison view={view} />
    ) : null
  }

  <a href="/runs" class="text-primary hover:text-primary/80 mt-6 inline-flex items-center gap-1 text-sm">
    ← Back to runs
  </a>
</AppLayout>
