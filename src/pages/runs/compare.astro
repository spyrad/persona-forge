---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getRunResult } from "@/lib/services/runs";
import { listPersonas } from "@/lib/services/personas";
import { listModelConfigs } from "@/lib/services/model-configs";
import type { ModelConfigView, PersonaView, RunComparisonSide, RunComparisonView, RunResultView } from "@/types";

// /runs/compare ist via PROTECTED_ROUTES (startsWith "/runs") geschuetzt. Diese
// statische Route schattet bewusst die dynamische /runs/[id] ab (sonst landet
// "compare" als id dort). Beide Laeufe werden RLS-gescoped geladen; alle
// Edge-Cases enden in einem erklaerenden Zustand statt einem 500.
const { user } = Astro.locals;
const a = Astro.url.searchParams.get("a") ?? "";
const b = Astro.url.searchParams.get("b") ?? "";

/** Loest die Anzeige-Labels eines Laufs aus den sichtbaren Persona-/Modell-Listen. */
function resolveSide(result: RunResultView, personas: PersonaView[], models: ModelConfigView[]): RunComparisonSide {
  const { run } = result;
  const persona = run.personaId ? personas.find((p) => p.id === run.personaId) : null;
  const model = run.modelConfigId ? models.find((m) => m.id === run.modelConfigId) : null;
  return {
    result,
    // FK auf null → der Bezug wurde geloescht; ID gesetzt aber nicht sichtbar
    // (z. B. fremde private Persona hinter globalem Lauf) → unbekannt.
    personaName: persona?.name ?? (run.personaId ? "(unbekannt)" : "(gelöscht)"),
    modelLabel: model?.label ?? (run.modelConfigId ? "(unbekannt)" : "(gelöscht)"),
    modelName: model?.modelName ?? null,
  };
}

/** Erklaerung fuer einen nicht-vergleichbaren (nicht `ready`) Lauf. */
function notReadyReason(result: RunResultView): string {
  return result.state === "unfinished" ? "ist noch nicht abgeschlossen" : "lieferte keine verwertbaren Wiederholungen";
}

type PageState = "missing" | "same" | "notFound" | "notReady" | "loadError" | "ready";

let pageState: PageState = "ready";
let view: RunComparisonView | null = null;
let notReadyDetail = "";

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase || !user) {
  pageState = "loadError";
} else if (!a || !b) {
  pageState = "missing";
} else if (a === b) {
  pageState = "same";
} else {
  try {
    const [ra, rb] = await Promise.all([getRunResult(supabase, user.id, a), getRunResult(supabase, user.id, b)]);
    if (!ra || !rb) {
      pageState = "notFound";
    } else if (ra.state !== "ready" || rb.state !== "ready") {
      pageState = "notReady";
      const parts: string[] = [];
      if (ra.state !== "ready") parts.push(`Lauf A ${notReadyReason(ra)}`);
      if (rb.state !== "ready") parts.push(`Lauf B ${notReadyReason(rb)}`);
      notReadyDetail = parts.join("; ");
    } else {
      const [personas, models] = await Promise.all([listPersonas(supabase, user.id), listModelConfigs(supabase)]);
      view = { a: resolveSide(ra, personas, models), b: resolveSide(rb, personas, models) };
    }
  } catch {
    pageState = "loadError";
  }
}

// Nicht sichtbar/vorhanden → 404 (Status ohne Top-Level-`return`; ein `return`
// im Astro-Frontmatter crasht die getypte no-misused-promises-Regel).
if (pageState === "notFound") {
  Astro.response.status = 404;
}
---

<Layout title="Läufe vergleichen">
  <div class="bg-cosmic min-h-screen px-4 py-10 text-white">
    <div class="mx-auto max-w-3xl">
      <header class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Läufe vergleichen
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">
          Zwei abgeschlossene OEJTS-Läufe nebeneinander — Verteilung je Achse mit ihren Streuungen.
        </p>
      </header>

      {
        pageState === "loadError" ? (
          <p class="rounded-2xl border border-red-500/30 bg-red-950/20 px-4 py-5 text-sm text-red-200">
            Vergleich konnte nicht geladen werden. Bitte neu laden.
          </p>
        ) : pageState === "missing" ? (
          <p class="rounded-2xl border border-white/10 bg-white/5 px-4 py-5 text-sm text-blue-100/70">
            Bitte zwei Läufe zum Vergleich auswählen — wähle sie in der Lauf-Liste über die „Vergleichen"-Haken aus.
          </p>
        ) : pageState === "same" ? (
          <p class="rounded-2xl border border-white/10 bg-white/5 px-4 py-5 text-sm text-blue-100/70">
            Bitte zwei <em>verschiedene</em> Läufe auswählen — ein Lauf lässt sich nicht mit sich selbst vergleichen.
          </p>
        ) : pageState === "notFound" ? (
          <p class="rounded-2xl border border-white/10 bg-white/5 px-4 py-5 text-sm text-blue-100/70">
            Mindestens einer der Läufe wurde nicht gefunden (gelöscht oder nicht sichtbar).
          </p>
        ) : pageState === "notReady" ? (
          <p class="rounded-2xl border border-amber-400/30 bg-amber-900/20 px-4 py-5 text-sm text-amber-200">
            Nicht vergleichbar: {notReadyDetail}. Nur abgeschlossene Läufe mit verwertbaren Wiederholungen lassen sich
            vergleichen.
          </p>
        ) : view ? (
          <div class="grid gap-4 sm:grid-cols-2">
            {[view.a, view.b].map((side, i) => (
              <div class="space-y-2 rounded-2xl border border-white/10 bg-white/5 p-5">
                <p class="text-xs text-blue-100/50">Lauf {i === 0 ? "A" : "B"}</p>
                <p class="font-semibold">{side.personaName}</p>
                <p class="text-sm text-blue-100/70">
                  {side.modelLabel}
                  {side.modelName ? ` (${side.modelName})` : ""}
                </p>
                <p class="text-xs text-blue-100/50">{new Date(side.result.run.createdAt).toLocaleString("de-DE")}</p>
                <p class="font-mono text-2xl font-bold tracking-widest">{side.result.aggregate?.modalType ?? "—"}</p>
              </div>
            ))}
          </div>
        ) : null
      }

      <a href="/runs" class="mt-6 inline-flex items-center gap-1 text-sm text-blue-200 hover:text-white">
        ← Zurück zu den Läufen
      </a>
    </div>
  </div>
</Layout>
