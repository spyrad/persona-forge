---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import { getRunResult } from "@/lib/services/runs";
import { listModelConfigs } from "@/lib/services/model-configs";
import type { RunResultView } from "@/types";
import RunResult from "@/components/runs/RunResult";

// /runs/[id] ist via PROTECTED_ROUTES (startsWith "/runs") geschuetzt.
const { user } = Astro.locals;
const id = Astro.params.id ?? "";

// Ergebnis server-seitig RLS-gescoped laden + on-the-fly aggregieren. Nicht
// sichtbar/vorhanden → 404. Service-Ausfall → loadError-Banner statt 500.
// Die Modellkonfigs kommen nur fuer die Profil-Querverlinkung dazu (5.1) — ihr
// Ausfall darf das Ergebnis nicht kippen, daher eigener try/catch: dann fehlt
// bloss der Link.
let result: RunResultView | null = null;
let modelName: string | null = null;
let loadError = false;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (supabase && user) {
  try {
    result = await getRunResult(supabase, user.id, id);
  } catch {
    loadError = true;
  }
  const modelConfigId = result?.run.modelConfigId ?? null;
  if (modelConfigId) {
    try {
      const configs = await listModelConfigs(supabase);
      modelName = configs.find((c) => c.id === modelConfigId)?.modelName ?? null;
    } catch {
      modelName = null;
    }
  }
} else {
  loadError = true;
}

// Nicht sichtbar/vorhanden → 404 (Status ohne Top-Level-`return` setzen; ein
// `return` im Astro-Frontmatter crasht die getypte no-misused-promises-Regel).
const notFound = !loadError && !result;
if (notFound) {
  Astro.response.status = 404;
}

// Untertitel je Test-Typ (run.kind ist immer gesetzt, auch bei unfertigen Läufen).
const resultSubtitle =
  result?.run.kind === "steadfastness"
    ? "Steadfastness (manipulation resistance): capitulation rate across experiments plus strategy breakdown."
    : result?.run.kind === "hexaco"
      ? "HEXACO distribution across repetitions: six personality factors (H/E/X/A/C/O), no single-type code."
      : "OEJTS distribution per axis across repetitions plus the derived type.";
---

<AppLayout title="Run result" eyebrow="04 — run result" heading="Run result" lead={resultSubtitle}>
  {
    loadError ? (
      <p class="border-destructive/30 bg-destructive/10 text-destructive rounded-2xl border px-4 py-5 text-sm">
        Could not load the result. Please reload.
      </p>
    ) : notFound ? (
      <div class="space-y-4">
        <p class="border-border bg-card text-muted-foreground rounded-2xl border px-4 py-5 text-sm">Run not found.</p>
        <a href="/runs" class="text-primary hover:text-primary/80 inline-flex items-center gap-1 text-sm">
          ← Back to runs
        </a>
      </div>
    ) : (
      result && <RunResult client:load result={result} modelName={modelName} />
    )
  }
</AppLayout>
