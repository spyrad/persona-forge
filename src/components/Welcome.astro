---
import { Card, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { buttonVariants } from "@/components/ui/button";

const features = [
  {
    title: "Gemeinfreie Tests",
    description: "Etablierte, frei nutzbare Instrumente (v1: OEJTS) — ohne Lizenzrisiko.",
  },
  {
    title: "N Wiederholungen",
    description: "Jeder Lauf wird mehrfach getrieben — Streuung statt zufälliger Einzelmessung.",
  },
  {
    title: "Verteilungen je Achse",
    description: "Mittelwert, Streuung und Typ-Stabilität pro Dimension, klar visualisiert.",
  },
];
---

<main class="mx-auto max-w-5xl px-4">
  <section class="flex flex-col items-center py-20 text-center sm:py-28">
    <h1 class="text-foreground max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
      Psychometrisches Profiling für LLMs
    </h1>
    <p class="text-muted-foreground mt-6 max-w-2xl text-lg">
      persona-forge fährt gemeinfreie Persönlichkeitstests mit N Wiederholungen gegen Sprachmodelle und liefert
      Verteilungen je Achse — statt einer einzelnen, zufälligen Momentaufnahme.
    </p>
    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      <a href="/auth/signin" class:list={buttonVariants({ size: "lg" })}>Anmelden</a>
      <a href="/auth/signup" class:list={buttonVariants({ variant: "outline", size: "lg" })}>Registrieren</a>
    </div>
  </section>

  <section class="grid grid-cols-1 gap-4 pb-24 sm:grid-cols-3">
    {
      features.map((f) => (
        <Card>
          <CardHeader>
            <CardTitle>{f.title}</CardTitle>
            <CardDescription>{f.description}</CardDescription>
          </CardHeader>
        </Card>
      ))
    }
  </section>
</main>
