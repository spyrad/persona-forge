---
import ThemeToggle from "@/components/ThemeToggle";
import { buttonVariants } from "@/components/ui/button";

const { user } = Astro.locals;
---

<header class="border-border bg-card border-b">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
    <div class="flex items-center gap-3">
      <a
        href={user ? "/dashboard" : "/"}
        class="text-foreground hover:text-primary text-base font-semibold tracking-tight transition-colors"
      >
        persona-forge
      </a>
      {
        user && (
          <a href="/dashboard" class:list={buttonVariants({ variant: "ghost", size: "sm" })}>
            Dashboard
          </a>
        )
      }
    </div>
    <nav class="flex items-center gap-1 text-sm">
      {
        user ? (
          <>
            <span class="text-muted-foreground mr-2 hidden sm:inline">{user.email}</span>
            <ThemeToggle client:load />
            <form method="POST" action="/api/auth/signout">
              <button type="submit" class:list={buttonVariants({ variant: "ghost", size: "sm" })}>
                Sign out
              </button>
            </form>
          </>
        ) : (
          <>
            <ThemeToggle client:load />
            <a href="/auth/signin" class:list={buttonVariants({ variant: "ghost", size: "sm" })}>
              Sign in
            </a>
            <a href="/auth/signup" class:list={buttonVariants({ variant: "default", size: "sm" })}>
              Sign up
            </a>
          </>
        )
      }
    </nav>
  </div>
</header>
