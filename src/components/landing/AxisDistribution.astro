---
import { AXES, RUNS_PER_AXIS, curvePoints, mean, simulateRun, stddev, toSvgArea, toSvgPath } from "./simulation";

interface Props {
  axisIndex?: number;
  seed?: number;
  showStats?: boolean;
  /** 16px horizontale Innenränder — spiegelt die Zeichenränder des Hero-Canvas (Hydration ohne Sprung). */
  inset?: boolean;
  class?: string;
}

const { axisIndex = 0, seed = 7, showStats = false, inset = false, class: className } = Astro.props;

const spec = AXES[axisIndex];
const values = simulateRun(spec, seed);
const m = mean(values);
const sd = stddev(values);

const W = 320;
const H = 102;
const BASELINE = H - 6;
const heights = curvePoints(m, Math.max(sd, 1.5), 48);
const curve = toSvgPath(heights, W, BASELINE - 8);
const area = toSvgArea(heights, W, BASELINE - 8);
const ticks = Array.from({ length: 11 }, (_, i) => (i / 10) * W);
---

<figure class:list={[className]}>
  <svg
    viewBox={`0 0 ${W} ${H}`}
    class:list={["h-auto w-full", inset && "px-4"]}
    role="img"
    aria-label={`Distribution on the ${spec.left}–${spec.right} axis`}
  >
    <path d={area} class="fill-primary/10" transform="translate(0 8)"></path>
    <path d={curve} class="stroke-primary fill-none" stroke-width="1.5" transform="translate(0 8)"></path>
    <line x1="0" y1={BASELINE} x2={W} y2={BASELINE} class="stroke-muted-foreground/40" stroke-width="1"></line>
    {
      ticks.map((x, i) => (
        <line
          x1={x}
          y1={BASELINE}
          x2={x}
          y2={BASELINE + (i % 5 === 0 ? 6 : 3)}
          class="stroke-muted-foreground/40"
          stroke-width="1"
        />
      ))
    }
  </svg>
  <div
    class:list={["text-muted-foreground mt-1 flex justify-between font-mono text-[11px]", inset && "px-4"]}
    aria-hidden="true"
  >
    <span>{spec.left}</span>
    <span>{spec.right}</span>
  </div>
  {
    showStats && (
      <figcaption class="text-muted-foreground mt-2 font-mono text-xs tabular-nums">
        {spec.left}–{spec.right} axis · n {RUNS_PER_AXIS} · mean {m.toFixed(1)} · σ {sd.toFixed(1)}
      </figcaption>
    )
  }
</figure>
