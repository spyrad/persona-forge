@@ -0,0 +1,20 @@
+import type { APIRoute } from "astro";
+import { z } from "zod";
+import { requireUser } from "@/lib/api-auth";
+import { badRequest, ok } from "@/lib/api-responses";
+
+const createTagSchema = z.object({ name: z.string().min(1).max(40) });
+
+export const POST: APIRoute = async ({ request, locals }) => {
+  const user = requireUser(locals);
+  const parsed = createTagSchema.safeParse(await request.json());
+  if (!parsed.success) return badRequest("Ungueltiger Name");
+
+  const slug = parsed.data.name.toLowerCase().replace(/\s+/g, "-");
+  const { data } = await locals.supabase
+    .from("tags")
+    .insert({ name: parsed.data.name, slug, owner_id: user.id })
+    .select()
+    .single();
+
+  return ok(data);
+};
