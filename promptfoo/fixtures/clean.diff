index 0000000..2222222
--- /dev/null
+++ b/src/pages/api/bookmarks/index.ts
@@ -0,0 +1,16 @@
+import type { APIRoute } from "astro";
+import { z } from "zod";
+import { requireUser } from "@/lib/api-auth";
+import { badRequest, ok } from "@/lib/api-responses";
+import { createBookmark } from "@/lib/services/bookmarks";
+
+export const prerender = false;
+
+const createBookmarkSchema = z.object({ label: z.string().min(1).max(80) });
+
+export const POST: APIRoute = async ({ request, locals }) => {
+  const user = requireUser(locals);
+  const parsed = createBookmarkSchema.safeParse(await request.json());
+  if (!parsed.success) return badRequest("Ungueltiges Label");
+
+  return ok(await createBookmark(locals.supabase, user.id, parsed.data.label));
+};
diff --git a/src/lib/services/bookmarks.ts b/src/lib/services/bookmarks.ts
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/src/lib/services/bookmarks.ts
@@ -0,0 +1,12 @@
+import type { SupabaseClient } from "@supabase/supabase-js";
+import type { Bookmark } from "@/types";
+
+export async function createBookmark(sb: SupabaseClient, ownerId: string, label: string): Promise<Bookmark> {
+  const { data, error } = await sb
+    .from("bookmarks")
+    .insert({ owner_id: ownerId, label })
+    .select()
+    .single();
+  if (error) throw new Error(error.message);
+  return data as Bookmark;
+}
