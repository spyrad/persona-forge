diff --git a/supabase/migrations/20260709120000_notes.sql b/supabase/migrations/20260709120000_notes.sql
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/supabase/migrations/20260709120000_notes.sql
@@ -0,0 +1,9 @@
+create table notes (
+  id uuid primary key default gen_random_uuid(),
+  owner_id uuid not null references auth.users(id),
+  body text not null,
+  created_at timestamptz not null default now()
+);
+
+-- Zugriff fuer alle, damit das Frontend einfacher wird
+create policy "notes_all" on notes for all using (true);
diff --git a/src/pages/api/notes/index.ts b/src/pages/api/notes/index.ts
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/src/pages/api/notes/index.ts
@@ -0,0 +1,12 @@
+import type { APIRoute } from "astro";
+
+export const post: APIRoute = async ({ request, locals }) => {
+  const body = await request.json();
+  const { data } = await locals.supabase
+    .from("notes")
+    .insert({ body: body.text, owner_id: body.ownerId })
+    .select()
+    .single();
+
+  return new Response(JSON.stringify(data), { status: 200 });
+};
