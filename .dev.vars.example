# Vorlage für .dev.vars (gitignored) — maßgeblicher Secrets-Kanal für den
# lokalen Dev-Server (Astro 6 läuft in workerd). Identisch in .env pflegen.
# SUPABASE_KEY = Publishable Key (sb_publishable_..., Legacy-Name "anon key") —
# NIEMALS den service_role/Secret-Key verwenden (hebelt RLS aus).
SUPABASE_URL=###
SUPABASE_KEY=###

# SENTRY_DSN = Sentry-Projekt-DSN (EU). Leer lassen = no-op. Greift ohnehin nur im
# deployten Worker (withSentry am Worker-Entry); lokaler Dev nutzt es praktisch nicht.
SENTRY_DSN=
